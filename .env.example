# Copy to .env and fill in. Vite only exposes vars prefixed with VITE_ to the app.

# Firebase web config — Project settings → General → Your apps → SDK setup.
VITE_FIREBASE_API_KEY=your-api-key
VITE_FIREBASE_AUTH_DOMAIN=your-project.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=your-project-id
VITE_FIREBASE_STORAGE_BUCKET=your-project.appspot.com
VITE_FIREBASE_MESSAGING_SENDER_ID=your-sender-id
VITE_FIREBASE_APP_ID=your-app-id

# Deployed `api` Cloud Function base URL (shown after `firebase deploy`).
VITE_FUNCTIONS_BASE_URL=https://us-central1-your-project-id.cloudfunctions.net/api
